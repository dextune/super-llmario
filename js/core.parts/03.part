
  /* ======================== 점수 시스템 ======================== */
  function calcStageScore(info) {
    var kill = (info.kills || 0) * 150;
    var prison = (info.prisoners || 0) * 1000;
    var timeBonus = Math.floor((info.timeRemaining || 0) * 15);
    var noHitBonus = info.noHit ? 10000 : 0;
    var grenadeBonus = (info.grenadesLeft || 0) * 100;
    return kill + prison + timeBonus + noHitBonus + grenadeBonus;
  }

  function scoreGrade(score) {
    if (score >= 40000) return 'S';
    if (score >= 28000) return 'A';
    if (score >= 16000) return 'B';
    if (score >= 8000) return 'C';
    return 'D';
  }

  function formatScore(n) { return String(Math.floor(n || 0)).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }

  /* ======================== 세이브 시스템 ======================== */
  function createSave() {
    return {
      version: SAVE_VERSION,
      unlockedStages: 1,
      highScores: {},
      totalKills: 0,
      totalPrisoners: 0,
      totalScore: 0,
      bestGrade: {},
    };
  }

  function validateSave(data) {
    if (!data || typeof data !== 'object') return createSave();
    var save = createSave();
    save.unlockedStages = clamp(data.unlockedStages || 1, 1, TOTAL_STAGES);
    save.highScores = (data.highScores && typeof data.highScores === 'object') ? data.highScores : {};
    save.totalKills = Math.max(0, data.totalKills || 0);
    save.totalPrisoners = Math.max(0, data.totalPrisoners || 0);
    save.totalScore = Math.max(0, data.totalScore || 0);
    save.bestGrade = (data.bestGrade && typeof data.bestGrade === 'object') ? data.bestGrade : {};
    return save;
  }

  function loadSave() {
    try {
      if (typeof localStorage === 'undefined') return null;
      var raw = localStorage.getItem(SAVE_KEY);
      if (!raw) return null;
      return validateSave(JSON.parse(raw));
    } catch (e) { return null; }
  }

  function saveSave(save) {
    try {
      if (typeof localStorage === 'undefined') return false;
      localStorage.setItem(SAVE_KEY, JSON.stringify(save));
      return true;
    } catch (e) { return false; }
  }

  function clearSave() {
    try {
      if (typeof localStorage === 'undefined') return;
      localStorage.removeItem(SAVE_KEY);
    } catch (e) {}
  }

  function unlockNextStage(save, stageId) {
    if (stageId + 1 < TOTAL_STAGES) {
      save.unlockedStages = Math.max(save.unlockedStages, stageId + 2);
    }
    return save;
  }

  function recordStageResult(save, stageId, score, grade, kills, prisoners) {
    var key = String(stageId);
    var prev = save.highScores[key] || 0;
    save.highScores[key] = Math.max(prev, score);
    var grades = { S: 5, A: 4, B: 3, C: 2, D: 1 };
    var prevGrade = save.bestGrade[key] || 'D';
    if ((grades[grade] || 0) > (grades[prevGrade] || 0)) save.bestGrade[key] = grade;
    save.totalKills += kills || 0;
    save.totalPrisoners += prisoners || 0;
    save.totalScore += score;
    return save;
  }

  function stageUnlocked(save, stageId) {
    return stageId < save.unlockedStages;
  }

  function allClear(save) {
    return save.unlockedStages >= TOTAL_STAGES &&
      Object.keys(save.highScores).length >= TOTAL_STAGES;
  }

  /* ======================== 내보내기 ======================== */
  return Object.freeze({
    SAVE_VERSION: SAVE_VERSION,
    SAVE_KEY: SAVE_KEY,
    TOTAL_STAGES: TOTAL_STAGES,
    MAX_HP: MAX_HP,
    START_GRENADES: START_GRENADES,
    MAX_LIVES: MAX_LIVES,

    WEAPONS: WEAPONS,
    WEAPON_KEYS: WEAPON_KEYS,
    WEAPON_DROP_RATES: WEAPON_DROP_RATES,
    randomWeaponDrop: randomWeaponDrop,

    ENEMY_TYPES: ENEMY_TYPES,
    BOSSES: BOSSES,
    STAGES: STAGES,

    clamp: clamp,
    hashString: hashString,
    makeRng: makeRng,

    calcStageScore: calcStageScore,
    scoreGrade: scoreGrade,
    formatScore: formatScore,

    createSave: createSave,
    validateSave: validateSave,
    loadSave: loadSave,
    saveSave: saveSave,
    clearSave: clearSave,
    unlockNextStage: unlockNextStage,
    recordStageResult: recordStageResult,
    stageUnlocked: stageUnlocked,
    allClear: allClear,
  });
});
