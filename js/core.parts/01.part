'use strict';

/* METAL STRIKE — 순수 아케이드 런앤건 도메인 계층
 * 브라우저/Node 양쪽에서 사용 가능하며 DOM, canvas, Audio에 의존하지 않는다.
 * 무기 · 스테이지 · 적 · 점수 · 세이브를 정의한다.
 */
(function initMS(root, factory) {
  const api = factory();
  if (typeof module === 'object' && module.exports) module.exports = api;
  else root.MS = api;
})(typeof globalThis !== 'undefined' ? globalThis : this, function buildMS() {
  'use strict';

  var SAVE_VERSION = 3;
  var SAVE_KEY = 'metal-strike-save-v3';
  var TOTAL_STAGES = 5;
  var MAX_HP = 100;
  var START_GRENADES = 10;
  var MAX_LIVES = 3;

  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }

  function hashString(value) {
    var h = 2166136261 >>> 0;
    var s = String(value);
    for (var i = 0; i < s.length; i++) {
      h ^= s.charCodeAt(i);
      h = Math.imul(h, 16777619);
    }
    return h >>> 0;
  }

  function makeRng(seed) {
    var state = (typeof seed === 'number' ? seed : hashString(seed || Date.now())) >>> 0;
    if (!state) state = 0x9e3779b9;
    return {
      random: function () {
        state ^= state << 13;
        state ^= state >>> 17;
        state ^= state << 5;
        return (state >>> 0) / 4294967296;
      },
      int: function (min, max) {
        return Math.floor(this.random() * (max - min + 1)) + min;
      },
      pick: function (list) {
        return list[Math.floor(this.random() * list.length)];
      },
      range: function (min, max) {
        return this.random() * (max - min) + min;
      },
      get state() { return state >>> 0; },
    };
  }

  /* ======================== 무기 정의 ======================== */
  // kind: projectile | spread | explosive | beam | flame
  var WEAPONS = {
    pistol: {
      id: 'pistol', name: '권총', letter: 'P', color: '#ffe066',
      kind: 'bullet', fireRate: 0.22, damage: 14, speed: 780, spread: 0.01,
      ammo: Infinity, pellets: 1, life: 0.7, shake: 0, casing: true,
      sfx: 'shoot', desc: '기본 무기 · 무한 탄환',
    },
    hmg: {
      id: 'hmg', name: '중기관총', letter: 'H', color: '#ff8c42',
      kind: 'bullet', fireRate: 0.055, damage: 9, speed: 900, spread: 0.06,
      ammo: 200, pellets: 1, life: 0.6, shake: 1.5, casing: true,
      sfx: 'mg', desc: '연사 화망 · 200발',
    },
    shotgun: {
      id: 'shotgun', name: '산탄총', letter: 'S', color: '#ff5e5e',
      kind: 'spread', fireRate: 0.6, damage: 11, speed: 700, spread: 0.28,
      ammo: 30, pellets: 6, life: 0.32, shake: 4, casing: true,
      sfx: 'shotgun', desc: '근접 폭풍 · 30발',
    },
    rocket: {
      id: 'rocket', name: '로켓런처', letter: 'R', color: '#ff3a3a',
      kind: 'explosive', fireRate: 0.75, damage: 70, speed: 420, spread: 0,
      ammo: 20, pellets: 1, life: 2.0, shake: 8, casing: false,
      radius: 70, sfx: 'rocket', desc: '광역 폭발 · 20발',
    },
    flame: {
      id: 'flame', name: '화염방사기', letter: 'F', color: '#ff6a1a',
      kind: 'flame', fireRate: 0.035, damage: 4.5, speed: 340, spread: 0.12,
      ammo: 80, pellets: 1, life: 0.35, shake: 0.5, casing: false,
      radius: 0, sfx: 'flame', desc: '지속 화염 · 80연료',
    },
    laser: {
      id: 'laser', name: '레이저건', letter: 'L', color: '#5cdbff',
      kind: 'beam', fireRate: 0.1, damage: 22, speed: 1400, spread: 0,
      ammo: 150, pellets: 1, life: 0.5, shake: 2, casing: false,
      piercing: true, sfx: 'laser', desc: '관통 광선 · 150발',
    },
  };
  var WEAPON_KEYS = ['pistol', 'hmg', 'shotgun', 'rocket', 'flame', 'laser'];
  var WEAPON_DROP_RATES = { hmg: 0.30, shotgun: 0.22, rocket: 0.15, flame: 0.16, laser: 0.17 };

  function randomWeaponDrop(rng) {
    var r = rng.random();
    var acc = 0;
    for (var k in WEAPON_DROP_RATES) {
      acc += WEAPON_DROP_RATES[k];
      if (r < acc) return k;
    }
    return 'hmg';
  }
