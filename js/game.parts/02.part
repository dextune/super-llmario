
  /* ==================================================================
     PLAYER · WEAPONS · PROJECTILES · PARTICLES
     ================================================================== */

  function createPlayer() {
    return {
      x: 80, y: GROUND_Y - 44, w: 28, h: 44, vx: 0, vy: 0,
      hp: MS.MAX_HP, maxHp: MS.MAX_HP, face: 1, onGround: true,
      crouch: false, invuln: 0, fireCd: 0, fireHeld: false,
      weapon: 'pistol', weaponAmmo: Infinity, grenades: MS.START_GRENADES,
      lives: MS.MAX_LIVES, animT: 0, animFrame: 0, dead: false,
      respawnT: 0, hurtT: 0, aimUp: false,
      dashT: 0, dashCd: 0, dashDir: 0,
    };
  }

  function updatePlayer(dt) {
    if (player.dead) {
      player.respawnT -= dt;
      if (player.respawnT <= 0) {
        if (player.lives > 0) {
          player.dead = false;
          player.hp = player.maxHp;
          player.x = Math.max(80, world.cameraX + 80);
          player.y = GROUND_Y - 44;
          player.vx = 0; player.vy = 0;
          player.invuln = 2.5;
          player.weapon = 'pistol';
          player.weaponAmmo = Infinity;
          player.grenades = MS.START_GRENADES;
          toast('REDEPLOY', '#5cdbff');
        } else {
          gameOver();
        }
      }
      return;
    }

    if (player.invuln > 0) player.invuln -= dt;
    if (player.hurtT > 0) player.hurtT -= dt;
    if (player.fireCd > 0) player.fireCd -= dt;
    if (player.dashT > 0) player.dashT -= dt;
    if (player.dashCd > 0) player.dashCd -= dt;

    // 대시 트리거 (더블탭)
    if (dashPressed !== 0 && player.dashCd <= 0 && player.dashT <= 0 && !player.dead) {
      player.dashT = 0.15;
      player.dashCd = 0.8;
      player.dashDir = dashPressed;
      player.invuln = Math.max(player.invuln, 0.18);
      Audio.sfx('dash');
      for (var di = 0; di < 4; di++) {
        world.particles.push({ x: player.x + player.w / 2, y: player.y + player.h / 2, vx: -player.dashDir * (60 + di * 30), vy: (Math.random() - 0.5) * 40, life: 0.2, maxLife: 0.2, color: '#7af5ff', size: 6 - di, type: 'flash' });
      }
    }
    dashPressed = 0;

    // 대시 중 이동
    if (player.dashT > 0) {
      player.vx = player.dashDir * 600;
      player.face = player.dashDir;
      // 잔상
      if (Math.random() < 0.6) {
        world.particles.push({ x: player.x, y: player.y, vx: 0, vy: 0, life: 0.15, maxLife: 0.15, color: '#7af5ff', size: player.w, type: 'afterimage', pw: player.w, ph: player.h, pface: player.face });
      }
    }

    player.aimUp = input.up && !input.down;
    player.crouch = input.down && player.onGround;

    var speed = (input.run ? 320 : 210) * (player.crouch ? 0.4 : 1);
    if (player.crouch) speed = 0;

    if (input.left && !input.right) { player.vx = -speed; player.face = -1; }
    else if (input.right && !input.left) { player.vx = speed; player.face = 1; }
    else player.vx *= 0.7;

    if (input.jump && player.onGround) {
      player.vy = -540;
      player.onGround = false;
      Audio.sfx('jump');
      addDust(player.x + player.w / 2, player.y + player.h, 4);
    }

    player.vy += GRAVITY * dt;
    player.x += player.vx * dt;
    player.y += player.vy * dt;

    if (player.y + player.h >= GROUND_Y) {
      if (!player.onGround && player.vy > 200) addDust(player.x + player.w / 2, GROUND_Y, 6);
      player.y = GROUND_Y - player.h;
      player.vy = 0;
      player.onGround = true;
    }

    player.x = clamp(player.x, world.cameraX, world.cameraX + VIEW_W - player.w);

    player.animT += dt;
    if (player.onGround && Math.abs(player.vx) > 20) {
      player.animFrame = Math.floor(player.animT * 14) % 4 + 1;
    } else if (!player.onGround) {
      player.animFrame = 5;
    } else {
      player.animFrame = 0;
    }

    if (input.fire && player.fireCd <= 0) tryFire();
    if (grenadePressed) { tryGrenade(); grenadePressed = false; }
  }

  function muzzleX() { return player.x + (player.face > 0 ? player.w + 4 : -4); }
  function muzzleY() { return player.crouch ? player.y + player.h * 0.3 : player.aimUp ? player.y - 2 : player.y + player.h * 0.35; }

  function tryFire() {
    var wpn = MS.WEAPONS[player.weapon];
    if (!wpn) return;
    if (player.weaponAmmo <= 0) {
      player.weapon = 'pistol';
      player.weaponAmmo = Infinity;
      player.fireCd = 0.3;
      toast('탄환 소진 — 권총으로 전환', '#ff9f5a');
      return;
    }
    player.fireCd = wpn.fireRate;

    var mx = muzzleX(), my = muzzleY();
    var dirX = player.aimUp ? 0 : player.face;
    var dirY = player.aimUp ? -1 : 0;

    if (wpn.kind === 'explosive') {
      spawnRocket(mx, my, dirX * wpn.speed, dirY * wpn.speed - (dirY === 0 ? 0 : 0), wpn);
    } else if (wpn.kind === 'arc') {
      spawnBullet(mx, my, dirX * wpn.speed, dirY * wpn.speed, wpn.damage, true, wpn.color, false);
      var ab = world.bullets[world.bullets.length - 1];
      ab.arc = true; ab.chainRange = wpn.chainRange; ab.maxChain = wpn.maxChain; ab.chainHit = {};
    } else if (wpn.kind === 'beam') {
      spawnBullet(mx, my, dirX * wpn.speed, dirY * wpn.speed, wpn.damage, true, wpn.color, true);
    } else {
      var ba = Math.atan2(dirY || 0.01, dirX) + (Math.random() - 0.5) * wpn.spread * 2;
      spawnBullet(mx, my, Math.cos(ba) * wpn.speed, Math.sin(ba) * wpn.speed, wpn.damage, true, '#ffe066');
    }

    addMuzzleFlash(mx, my, player.face, player.aimUp);
    if (wpn.casing) addCasing(muzzleX() - player.face * 8, player.y + 12, player.face);
    Audio.sfx(wpn.sfx);

    if (player.weaponAmmo !== Infinity) player.weaponAmmo--;
  }

  function tryGrenade() {
    if (player.dead || player.grenades <= 0) return;
    player.grenades--;
    var gx = player.x + player.w / 2 + player.face * 20;
    var gy = player.y + 10;
    world.grenades.push({
      x: gx, y: gy, w: 8, h: 8, vx: player.face * 260, vy: -320, life: 2.0,
    });
    Audio.sfx('itemdrop');
    addDust(gx, gy, 2);
  }

  function hurtPlayer(amount) {
    if (player.dead || player.invuln > 0) return;
    player.hp -= amount;
    player.invuln = 1.2;
    player.hurtT = 0.3;
    world.hitFlag = true;
    screenFlash('#ff0000', 0.12);
    Audio.sfx('hurt');
    addBlood(centerX(player), centerY(player), 6, '#ff4040');
    if (player.hp <= 0) killPlayer();
  }

  function killPlayer() {
    player.dead = true;
    player.lives--;
    player.respawnT = 2.0;
    screenFlash('#ff0000', 0.3);
    explodeAt(centerX(player), centerY(player), 50, '#ff5e3a');
    Audio.sfx('die');
  }

  /* ===== 투사체 ===== */
  function spawnBullet(x, y, vx, vy, dmg, fromPlayer, color, piercing) {
    world.bullets.push({
      x: x - 3, y: y - 2, w: 6, h: 4, vx: vx, vy: vy, dmg: dmg,
      fromPlayer: fromPlayer, color: color || '#ffe066', life: 0.7,
      piercing: !!piercing, hitSet: {},
    });
  }
  function spawnEnemyBullet(x, y, vx, vy, dmg, color) {
    world.bullets.push({
      x: x - 3, y: y - 3, w: 6, h: 6, vx: vx, vy: vy, dmg: dmg,
      fromPlayer: false, color: color || '#ff5e5e', life: 3.0,
      piercing: false, hitSet: {}, enemy: true,
    });
  }
  function spawnRocket(x, y, vx, vy, wpn) {
    world.rockets.push({
      x: x - 4, y: y - 3, w: 8, h: 6, vx: vx, vy: vy, dmg: wpn.damage,
      radius: wpn.radius, life: wpn.life, smokeT: 0,
    });
    Audio.sfx('rocket');
  }
  function spawnFlame(x, y, vx, vy, dmg) {
    world.flames.push({ x: x - 3, y: y - 3, w: 6, h: 6, vx: vx, vy: vy, dmg: dmg, life: 0.35, maxLife: 0.35 });
  }

  function triggerArcChain(source, bullet) {
    var chainDmg = bullet.dmg * 0.7;
    var chainsLeft = bullet.maxChain - 1;
    var hitIds = {};
    hitIds[source.id] = true;
    var cx = centerX(source), cy = centerY(source);

    for (var c = 0; c < chainsLeft; c++) {
      var best = null, bestDist = bullet.chainRange;
      for (var j = 0; j < world.enemies.length; j++) {
        var ne = world.enemies[j];
        if (ne.dead || hitIds[ne.id]) continue;
        var d = Math.hypot(centerX(ne) - cx, centerY(ne) - cy);
        if (d < bestDist) { bestDist = d; best = ne; }
      }
      if (world.boss && !world.boss.dead && !hitIds['boss']) {
        var bd = Math.hypot(centerX(world.boss) - cx, centerY(world.boss) - cy);
        if (bd < bestDist) { bestDist = bd; best = world.boss; hitIds['boss'] = true; }
      }
      if (!best) break;

      var nx = centerX(best), ny = centerY(best);
      world.effects.push({ type: 'arc', x1: cx, y1: cy, x2: nx, y2: ny, life: 0.15, maxLife: 0.15, color: bullet.color || '#7af5ff' });
      if (best === world.boss) { damageBoss(best, chainDmg); }
      else { damageEnemy(best, chainDmg, nx > cx ? 1 : -1); }
      addSpark(nx, ny, '#7af5ff');
      hitIds[best.id] = true;
      cx = nx; cy = ny;
      chainDmg *= 0.7;
    }
    Audio.sfx('arc');
  }

  function updateProjectiles(dt) {
    for (var i = world.bullets.length - 1; i >= 0; i--) {
      var b = world.bullets[i];
      b.x += b.vx * dt; b.y += b.vy * dt; b.life -= dt;
      if (b.life <= 0 || b.x < world.cameraX - 100 || b.x > world.cameraX + VIEW_W + 100) { world.bullets.splice(i, 1); continue; }
      if (b.fromPlayer) {
        for (var j = 0; j < world.enemies.length; j++) {
          var e = world.enemies[j];
          if (e.dead || b.hitSet[e.id]) continue;
          if (overlap(b, e)) {
            if (b.piercing) { b.hitSet[e.id] = true; } else { world.bullets.splice(i, 1); }
            damageEnemy(e, b.dmg, b.vx > 0 ? 1 : -1);
            addSpark(centerX(b) - b.vx * 0.01, centerY(b), b.color);
            if (b.arc) triggerArcChain(e, b);
            break;
          }
        }
        if (world.boss && !world.boss.dead && world.bullets[i] && overlap(world.bullets[i], world.boss)) {
          damageBoss(world.boss, b.dmg);
          addSpark(centerX(b), centerY(b), '#ffe066');
          if (!b.piercing) world.bullets.splice(i, 1);
        }
        // 드럼통 충돌
        if (world.bullets[i] && b.fromPlayer) {
          for (var bki = 0; bki < world.barrels.length; bki++) {
            var bk = world.barrels[bki];
            if (!bk.dead && overlap(world.bullets[i], bk)) {
              explodeBarrel(bk);
              if (!b.piercing) world.bullets.splice(i, 1);
              break;
            }
          }
        }
      } else {
        if (player && !player.dead && overlap(b, player)) {
          world.bullets.splice(i, 1);
          hurtPlayer(b.dmg);
        }
      }
    }

    for (var ri = world.rockets.length - 1; ri >= 0; ri--) {
      var rk = world.rockets[ri];
      rk.x += rk.vx * dt; rk.y += rk.vy * dt; rk.life -= dt;
      rk.smokeT -= dt;
      if (rk.smokeT <= 0) { rk.smokeT = 0.03; addSmoke(rk.x, rk.y); }
      var hit = false;
      for (var re = 0; re < world.enemies.length; re++) {
        var ren = world.enemies[re];
        if (!ren.dead && overlap(rk, ren)) { explodeAt(centerX(rk), centerY(rk), rk.radius, '#ff6a2a'); damageEnemyArea(centerX(rk), centerY(rk), rk.radius, rk.dmg); hit = true; break; }
      }
      if (!hit && world.boss && !world.boss.dead && overlap(rk, world.boss)) { explodeAt(centerX(rk), centerY(rk), rk.radius, '#ff6a2a'); damageBoss(world.boss, rk.dmg); hit = true; }
      if (!hit && rk.y + rk.h >= GROUND_Y) { explodeAt(centerX(rk), GROUND_Y, rk.radius, '#ff6a2a'); damageEnemyArea(centerX(rk), GROUND_Y, rk.radius, rk.dmg); hit = true; }
      if (hit || rk.life <= 0) world.rockets.splice(ri, 1);
    }

    for (var fi = world.flames.length - 1; fi >= 0; fi--) {
      var fl = world.flames[fi];
      fl.x += fl.vx * dt; fl.y += fl.vy * dt; fl.vy += 100 * dt; fl.life -= dt;
      if (fl.life <= 0) { world.flames.splice(fi, 1); continue; }
      for (var fe = 0; fe < world.enemies.length; fe++) {
        var fen = world.enemies[fe];
        if (!fen.dead && overlap(fl, fen)) {
          fen.burn = 0.5;
          fen._flameCd = (fen._flameCd || 0) - dt;
          if (fen._flameCd <= 0) { fen._flameCd = 0.08; damageEnemy(fen, fl.dmg * 6, fl.vx > 0 ? 1 : -1); }
        }
      }
      if (world.boss && !world.boss.dead && overlap(fl, world.boss)) {
        world.boss._flameCd = (world.boss._flameCd || 0) - dt;
        if (world.boss._flameCd <= 0) { world.boss._flameCd = 0.08; damageBoss(world.boss, fl.dmg * 6); }
      }
    }

    for (var gi = world.grenades.length - 1; gi >= 0; gi--) {
      var gr = world.grenades[gi];
      gr.vy += GRAVITY * 0.7 * dt;
      gr.x += gr.vx * dt; gr.y += gr.vy * dt; gr.life -= dt;
      if (gr.y + gr.h >= GROUND_Y) { gr.y = GROUND_Y - gr.h; gr.vy *= -0.4; gr.vx *= 0.7; }
      var gHit = gr.life <= 0;
      for (var ge = 0; ge < world.enemies.length; ge++) {
        if (!world.enemies[ge].dead && overlap(gr, world.enemies[ge])) { gHit = true; break; }
      }
      if (gr.enemy && player && !player.dead && overlap(gr, player)) gHit = true;
      if (gHit) {
        explodeAt(centerX(gr), centerY(gr), 65, '#ff8c42');
        damageEnemyArea(centerX(gr), centerY(gr), 65, 55);
        if (gr.enemy && player && !player.dead && Math.hypot(centerX(player) - centerX(gr), centerY(player) - centerY(gr)) < 65) hurtPlayer(22);
        world.grenades.splice(gi, 1);
      }
    }
  }

  function explodeAt(x, y, radius, color) {
    screenFlash(color, 0.08);
    Audio.sfx('explode');
    for (var i = 0; i < 16; i++) {
      var a = Math.random() * Math.PI * 2;
      var s = 80 + Math.random() * 220;
      world.particles.push({
        x: x, y: y, vx: Math.cos(a) * s, vy: Math.sin(a) * s,
        life: 0.3 + Math.random() * 0.4, maxLife: 0.7,
        color: i % 3 === 0 ? '#ffe066' : i % 3 === 1 ? '#ff6a2a' : color,
        size: 4 + Math.random() * 5, type: 'spark',
      });
    }
    world.effects.push({ type: 'shockwave', x: x, y: y, r: radius, life: 0.4, maxLife: 0.4, color: '#ffe066' });
    world.effects.push({ type: 'flash', x: x, y: y, r: radius * 0.6, life: 0.2, maxLife: 0.2, color: '#ffffff' });
  }

  function explodeBarrel(barrel) {
    if (barrel.dead) return;
    barrel.dead = true;
    var bx = centerX(barrel), by = centerY(barrel);
    explodeAt(bx, by, 80, '#ff6a2a');
    damageEnemyArea(bx, by, 80, 60);
    if (player && !player.dead && Math.hypot(centerX(player) - bx, centerY(player) - by) < 80) hurtPlayer(25);
    // 연쇄 폭발
    for (var i = 0; i < world.barrels.length; i++) {
      var ob = world.barrels[i];
      if (!ob.dead && ob !== barrel && Math.hypot(centerX(ob) - bx, centerY(ob) - by) < 120) {
        setTimeout(function (o) { explodeBarrel(o); }, 120, ob);
      }
    }
    world.score += 50;
    addFloat(bx, by - 20, '+50', '#ff8c42', 10);
  }

  function damageEnemyArea(x, y, radius, dmg) {
    for (var i = 0; i < world.enemies.length; i++) {
      var e = world.enemies[i];
      if (e.dead) continue;
      if (Math.hypot(centerX(e) - x, centerY(e) - y) < radius) damageEnemy(e, dmg, centerX(e) < x ? -1 : 1);
    }
    if (world.boss && !world.boss.dead && Math.hypot(centerX(world.boss) - x, centerY(world.boss) - y) < radius) damageBoss(world.boss, dmg);
  }

  /* ===== 파티클 & 이펙트 ===== */
  function addMuzzleFlash(x, y, face, up) {
    world.particles.push({ x: x, y: y, vx: face * 60, vy: (up ? -60 : 0), life: 0.06, maxLife: 0.06, color: '#ffe066', size: 8, type: 'flash' });
    world.particles.push({ x: x + face * 4, y: y, vx: face * 30, vy: 0, life: 0.08, maxLife: 0.08, color: '#ffffff', size: 5, type: 'flash' });
  }
  function addCasing(x, y, face) {
    world.particles.push({ x: x, y: y, vx: -face * (40 + Math.random() * 60), vy: -120 - Math.random() * 80, life: 0.8, maxLife: 0.8, color: '#e8b830', size: 3, type: 'casing', gravity: true, bounce: true });
  }
  function addDust(x, y, count) {
    for (var i = 0; i < count; i++) world.particles.push({ x: x + (Math.random() - 0.5) * 20, y: y, vx: (Math.random() - 0.5) * 80, vy: -20 - Math.random() * 40, life: 0.3 + Math.random() * 0.2, maxLife: 0.5, color: '#aaaa88', size: 3 + Math.random() * 3, type: 'dust' });
  }
  function addSpark(x, y, color) {
    for (var i = 0; i < 4; i++) { var a = Math.random() * Math.PI * 2; var s = 50 + Math.random() * 100; world.particles.push({ x: x, y: y, vx: Math.cos(a) * s, vy: Math.sin(a) * s, life: 0.15, maxLife: 0.15, color: color || '#ffe066', size: 2 + Math.random() * 2, type: 'spark' }); }
  }
  function addBlood(x, y, count, color) {
    for (var i = 0; i < count; i++) { var a = Math.random() * Math.PI * 2; var s = 60 + Math.random() * 140; world.particles.push({ x: x, y: y, vx: Math.cos(a) * s, vy: Math.sin(a) * s - 50, life: 0.3 + Math.random() * 0.3, maxLife: 0.6, color: color || '#cc2a2a', size: 2 + Math.random() * 3, type: 'blood', gravity: true }); }
  }
  function addSmoke(x, y) {
    world.particles.push({ x: x, y: y, vx: (Math.random() - 0.5) * 20, vy: -20 - Math.random() * 30, life: 0.5, maxLife: 0.5, color: '#888888', size: 4 + Math.random() * 4, type: 'smoke' });
  }
  function addFloat(x, y, text, color, size) {
    world.floats.push({ x: x, y: y, text: text, color: color || '#ffffff', size: size || 14, life: 0.9, maxLife: 0.9 });
  }

  function updateParticles(dt) {
    for (var i = world.particles.length - 1; i >= 0; i--) {
      var p = world.particles[i];
      p.x += p.vx * dt; p.y += p.vy * dt;
      if (p.gravity) p.vy += 600 * dt;
      if (p.bounce && p.y > GROUND_Y) { p.y = GROUND_Y; p.vy *= -0.4; p.vx *= 0.6; }
      if (p.type === 'smoke') p.size += 20 * dt;
      p.life -= dt;
      if (p.life <= 0) world.particles.splice(i, 1);
    }
    for (var e = world.effects.length - 1; e >= 0; e--) {
      world.effects[e].life -= dt;
      if (world.effects[e].life <= 0) world.effects.splice(e, 1);
    }
    for (var f = world.floats.length - 1; f >= 0; f--) {
      world.floats[f].y -= 40 * dt; world.floats[f].life -= dt;
      if (world.floats[f].life <= 0) world.floats.splice(f, 1);
    }
    if (flashT > 0) flashT -= dt;
    if (toastT > 0) toastT -= dt;
  }
