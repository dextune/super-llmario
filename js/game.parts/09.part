    Audio.ensure();
    if (state === STATE.TITLE && code === 'Enter') { if (loadProfile()) continueGame(); else { setState(STATE.CLASS, 'class'); renderClassSelect(); } return; }
    if (state === STATE.PAUSED && (code === 'Escape' || code === 'KeyP' || code === 'Enter')) { pause(); return; }
    if (state === STATE.INVENTORY && (code === 'Escape' || code === 'KeyI' || code === 'Tab')) { closeMetaPanel(); return; }
    if ([STATE.SHOP, STATE.FORGE, STATE.SKILLS, STATE.QUESTS].includes(state) && code === 'Escape') { enterHub(); return; }
    if (state !== STATE.FIELD) return;
    if (code === 'ArrowLeft' || code === 'KeyA') input.left = true;
    if (code === 'ArrowRight' || code === 'KeyD') input.right = true;
    if (code === 'ShiftLeft' || code === 'ShiftRight') input.run = true;
    if (code === 'Space' || code === 'ArrowUp' || code === 'KeyW') { input.jump = true; if (!event.repeat) player.jumpBuffer = 0.12; }
    if (code === 'KeyJ' && !event.repeat) basicAttack();
    if (code === 'KeyK' && !event.repeat) primarySkill();
    if (code === 'KeyL' && !event.repeat) secondarySkill();
    if (code === 'KeyQ' && !event.repeat) usePotion('hp');
    if (code === 'KeyE' && !event.repeat) usePotion('mp');
    if (code === 'KeyI' && !event.repeat) openInventory(STATE.FIELD);
    if ((code === 'Escape' || code === 'KeyP') && !event.repeat) pause();
  });

  document.addEventListener('keyup', event => {
    const code = event.code;
    if (code === 'ArrowLeft' || code === 'KeyA') input.left = false;
    if (code === 'ArrowRight' || code === 'KeyD') input.right = false;
    if (code === 'ShiftLeft' || code === 'ShiftRight') input.run = false;
    if (code === 'Space' || code === 'ArrowUp' || code === 'KeyW') input.jump = false;
  });

  if (cvs.addEventListener) {
    cvs.addEventListener('pointerdown', event => {
      if (state !== STATE.FIELD) return;
      if (event.button === 2) primarySkill(); else basicAttack();
    });
    cvs.addEventListener('contextmenu', event => event.preventDefault && event.preventDefault());
  }

  function bindTouch(id, down, up) {
    const el = $(id); if (!el || !el.addEventListener) return;
    el.addEventListener('pointerdown', event => { if (event.preventDefault) event.preventDefault(); down(); });
    for (const name of ['pointerup', 'pointercancel', 'pointerleave']) el.addEventListener(name, event => { if (event.preventDefault) event.preventDefault(); if (up) up(); });
  }
  bindTouch('tb-left', () => { input.left = true; }, () => { input.left = false; });
  bindTouch('tb-right', () => { input.right = true; }, () => { input.right = false; });
  bindTouch('tb-run', () => { input.run = true; }, () => { input.run = false; });
  bindTouch('tb-jump', () => { if (state === STATE.FIELD) { input.jump = true; player.jumpBuffer = 0.12; } }, () => { input.jump = false; });
  bindTouch('tb-atk', basicAttack);
  bindTouch('tb-primary', primarySkill);
  bindTouch('tb-secondary', secondarySkill);
  bindTouch('tb-pot', () => usePotion('hp'));

  const soundButton = $('btn-sound');
  if (soundButton && soundButton.addEventListener) soundButton.addEventListener('click', event => {
    Audio.ensure(); const muted = Audio.toggle(); soundButton.textContent = muted ? 'SOUND OFF' : 'SOUND ON';
    if (profile) { profile.settings.sound = !muted; saveProfile(true); }
    if (event.stopPropagation) event.stopPropagation();
  });

  renderClassSelect();
  updateContinueButton();
  showOverlay('title');
  lastTime = nowMs();
  if (root.requestAnimationFrame) rafId = root.requestAnimationFrame(frame);
  else render();

  root.SuperLLMarioRPG2 = Object.freeze({
    STATE,
    get state() { return state; },
    get profile() { return profile; },
    get world() { return world; },
    get player() { return player; },
    startNew, continueGame, enterHub, startStage, pause, openInventory,
    basicAttack, primarySkill, secondarySkill, usePotion,
    saveProfile, loadProfile, deleteSave,
    tick, render,
    snapshot() {
      return {
        state, profile: profile ? RPG.deepClone(profile) : null,
        world: world ? { stageIndex: world.stageIndex, elapsed: world.elapsed, kills: world.kills, objectiveDone: world.objectiveDone } : null,
        player: player ? { x: player.x, y: player.y, hp: player.hp, mp: player.mp } : null,
        rafId,
      };
    },
  });
})(typeof globalThis !== 'undefined' ? globalThis : window);
