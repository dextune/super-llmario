'use strict';

/* METAL STRIKE — 브라우저 런앤건 런타임
 * MS 도메인 계층 위에 스테이지 선택 → 런앤건 → 보스 → 클리어 흐름을 조립한다.
 */
(function bootMetalStrike(root) {
  var MS = root.MS;
  if (!MS || typeof document === 'undefined') return;

  var SAVE_KEY = MS.SAVE_KEY;
  var STATE = Object.freeze({
    TITLE: 'title', SELECT: 'select', BRIEF: 'brief',
    PLAY: 'play', PAUSED: 'paused', CLEAR: 'clear',
    OVER: 'over', WIN: 'win',
  });
  var VIEW_W = 960, VIEW_H = 624, GROUND_Y = 540;
  var GRAVITY = 1500;
  var $ = function (id) { return document.getElementById(id); };
  var cvs = $('game');
  if (!cvs || !cvs.getContext) return;
  var g = cvs.getContext('2d');
  if (!g) return;
  g.imageSmoothingEnabled = false;

  var Audio = (typeof AudioSys !== 'undefined' ? AudioSys : root.AudioSys) || {
    ensure: function () {}, sfx: function () {}, musicStart: function () {},
    musicStop: function () {}, toggle: function () { return false; },
  };

  /* ===== 글로벌 상태 ===== */
  var state = STATE.TITLE;
  var save = MS.createSave();
  var world = null;
  var player = null;
  var selectedStage = 0;
  var rafId = 0;
  var lastTime = typeof performance !== 'undefined' && performance.now ? performance.now() : Date.now();
  var titleT = 0;
  var stateT = 0;
  var flashT = 0;
  var flashColor = '#ffffff';
  var toastT = 0;
  var toastText = '';
  var toastColor = '#ffffff';

  /* ===== 입력 ===== */
  var keys = {};
  var input = { left: false, right: false, up: false, down: false, jump: false, fire: false, run: false };
  var firePressed = false;
  var grenadePressed = false;
  var pausePressed = false;

  function onKeyDown(e) {
    if (keys[e.code]) return;
    keys[e.code] = true;
    Audio.ensure();
    var c = e.code;

    if (state === STATE.TITLE) {
      if (c === 'Enter' || c === 'Space') { goSelect(); e.preventDefault(); return; }
    } else if (state === STATE.SELECT) {
      if (c === 'Enter' || c === 'Space') { startStage(selectedStage); e.preventDefault(); return; }
      if (c === 'ArrowLeft' || c === 'KeyA') { selectedStage = Math.max(0, selectedStage - 1); Audio.sfx('menu'); e.preventDefault(); return; }
      if (c === 'ArrowRight' || c === 'KeyD') { selectedStage = Math.min(save.unlockedStages - 1, selectedStage + 1); Audio.sfx('menu'); e.preventDefault(); return; }
    } else if (state === STATE.BRIEF) {
      if (c === 'Enter' || c === 'Space') { beginPlay(); e.preventDefault(); return; }
    } else if (state === STATE.PLAY) {
      if (c === 'KeyP' || c === 'Escape') { state = STATE.PAUSED; Audio.musicStop(); e.preventDefault(); return; }
      if (c === 'KeyK') grenadePressed = true;
    } else if (state === STATE.PAUSED) {
      if (c === 'KeyP' || c === 'Escape') { state = STATE.PLAY; Audio.musicStart(); e.preventDefault(); return; }
      if (c === 'KeyQ') { state = STATE.TITLE; titleT = 0; Audio.musicStop(); e.preventDefault(); return; }
    } else if (state === STATE.CLEAR) {
      if (c === 'Enter' || c === 'Space') { nextStage(); e.preventDefault(); return; }
    } else if (state === STATE.OVER) {
      if (c === 'Enter' || c === 'Space') { retryStage(); e.preventDefault(); return; }
      if (c === 'KeyQ') { state = STATE.TITLE; titleT = 0; e.preventDefault(); return; }
    } else if (state === STATE.WIN) {
      if (c === 'Enter' || c === 'Space') { state = STATE.TITLE; titleT = 0; e.preventDefault(); return; }
    }

    if (c === 'Space' || c === 'ArrowUp' || c === 'KeyW') input.jump = true;
    if (c === 'ArrowLeft' || c === 'KeyA') input.left = true;
    if (c === 'ArrowRight' || c === 'KeyD') input.right = true;
    if (c === 'ArrowDown' || c === 'KeyS') input.down = true;
    if (c === 'KeyJ') { input.fire = true; firePressed = true; }
    if (c === 'ShiftLeft' || c === 'ShiftRight') input.run = true;
    if (e.code === 'Space' || c.indexOf('Arrow') === 0) e.preventDefault();
  }

  function onKeyUp(e) {
    keys[e.code] = false;
    var c = e.code;
    if (c === 'Space' || c === 'ArrowUp' || c === 'KeyW') input.jump = false;
    if (c === 'ArrowLeft' || c === 'KeyA') input.left = false;
    if (c === 'ArrowRight' || c === 'KeyD') input.right = false;
    if (c === 'ArrowDown' || c === 'KeyS') input.down = false;
    if (c === 'KeyJ') input.fire = false;
    if (c === 'ShiftLeft' || c === 'ShiftRight') input.run = false;
  }

  /* ===== 유틸 ===== */
  function nowMs() { return typeof performance !== 'undefined' && performance.now ? performance.now() : Date.now(); }
  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }
  function overlap(a, b) { return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y; }
  function centerX(o) { return o.x + o.w / 2; }
  function centerY(o) { return o.y + o.h / 2; }
  function dist(a, b) { return Math.hypot(centerX(a) - centerX(b), centerY(a) - centerY(b)); }
  function fmt(n) { return MS.formatScore(n); }

  function toast(text, color) { toastText = text; toastColor = color || '#ffffff'; toastT = 2.5; }
  function screenFlash(color, dur) { flashColor = color; flashT = dur || 0.15; }

  /* ===== 세이브 ===== */
  function loadSaveData() { var s = MS.loadSave(); return s || MS.createSave(); }
  function saveData() { MS.saveSave(save); }

  function goSelect() { state = STATE.SELECT; stateT = 0; selectedStage = 0; Audio.sfx('menu'); }
  function goTitle() { state = STATE.TITLE; titleT = 0; Audio.musicStop(); }
