    for (const f of world.floats) { f.life -= dt; f.y -= 34 * dt; }
    world.floats = world.floats.filter(f => f.life > 0);
    for (const e of world.effects) e.life -= dt;
    world.effects = world.effects.filter(e => e.life > 0);
    if (world.shake > 0) world.shake -= dt;
  }

  function updateField(dt) {
    if (!world || !player || world.finished) return;
    world.elapsed += dt;
    world.remaining = Math.max(0, world.stage.timeLimit - world.elapsed);
    if (world.remaining <= 0) { failStage('제한 시간 초과'); return; }
    profile.playSeconds += dt;
    accSave += dt;
    if (accSave >= 25) { accSave = 0; saveProfile(true); }
    updatePlayer(dt);
    if (state !== STATE.FIELD) return;
    const initialLength = world.enemies.length;
    for (let i = 0; i < initialLength; i++) updateEnemy(world.enemies[i], dt);
    if (state !== STATE.FIELD) return;
    updateProjectiles(dt);
    if (state !== STATE.FIELD) return;
    updateDrops(dt);
    updateEnvironment(dt);
    updateFx(dt);
    world.enemies = world.enemies.filter(e => !e.dead);
    updateObjective();
  }

  function drawBar(x, y, w, h, ratio, color, bg) {
    g.fillStyle = bg || 'rgba(0,0,0,.65)'; g.fillRect(x, y, w, h);
    g.fillStyle = color; g.fillRect(x, y, w * clamp(ratio, 0, 1), h);
    g.strokeStyle = 'rgba(255,255,255,.25)'; g.strokeRect(x, y, w, h);
  }

  function drawTown() {
    const grd = g.createLinearGradient(0, 0, 0, VIEW_H);
    grd.addColorStop(0, '#17152d'); grd.addColorStop(1, '#513a52');
    g.fillStyle = grd; g.fillRect(0, 0, VIEW_W, VIEW_H);
    for (let i = 0; i < 18; i++) {
      const x = (i * 87 + titleT * 8) % (VIEW_W + 60) - 30;
      g.fillStyle = 'rgba(255,238,174,.5)'; g.fillRect(x, 70 + (i * 53) % 190, 2, 2);
    }
    g.fillStyle = '#201a2e'; g.fillRect(0, 480, VIEW_W, 144);
    for (let i = 0; i < 7; i++) {
      const x = 40 + i * 145, h = 100 + (i % 3) * 35;
      g.fillStyle = i % 2 ? '#48324a' : '#3b2d43'; g.fillRect(x, 480 - h, 110, h);
      g.fillStyle = '#201827'; g.beginPath(); g.moveTo(x - 12, 480 - h); g.lineTo(x + 55, 480 - h - 48); g.lineTo(x + 122, 480 - h); g.fill();
      g.fillStyle = '#ffd46b'; g.fillRect(x + 20, 430, 12, 18); g.fillRect(x + 72, 430, 12, 18);
    }
    g.fillStyle = '#ffd46b'; g.beginPath(); g.arc(790, 110, 44, 0, Math.PI * 2); g.fill();
    g.fillStyle = 'rgba(255,255,255,.08)'; g.font = '58px "Press Start 2P", monospace'; g.fillText('RPG', 365, 220);
  }

  function drawFieldBackground() {
    const th = world.stage.theme;
    const grd = g.createLinearGradient(0, 0, 0, VIEW_H);
    grd.addColorStop(0, th.sky); grd.addColorStop(1, th.far);
    g.fillStyle = grd; g.fillRect(0, 0, VIEW_W, VIEW_H);
    g.globalAlpha = 0.18;
    for (let i = 0; i < 8; i++) {
      const x = ((i * 240 - world.cameraX * 0.25) % 2100 + 2100) % 2100 - 180;
      g.fillStyle = th.accent; g.beginPath(); g.arc(x, GROUND_Y + 30, 130 + (i % 2) * 55, Math.PI, 0); g.fill();
    }
    g.globalAlpha = 1;
  }

  function drawWorld() {
    const cam = world.cameraX;
    let shakeX = 0, shakeY = 0;
    if (world.shake > 0) { shakeX = (Math.random() * 2 - 1) * 8; shakeY = (Math.random() * 2 - 1) * 5; }
    g.save(); g.translate(-Math.round(cam) + shakeX, shakeY);
    const th = world.stage.theme;
    g.fillStyle = th.ground;
    let start = Math.floor(cam / 80) * 80 - 80;
    for (let x = start; x < cam + VIEW_W + 120; x += 80) if (groundExistsAt(x + 40)) g.fillRect(x, GROUND_Y, 82, VIEW_H - GROUND_Y);
    g.fillStyle = th.accent;
    for (let x = start; x < cam + VIEW_W + 120; x += 80) if (groundExistsAt(x + 40)) g.fillRect(x, GROUND_Y, 82, 7);
    for (const platform of world.platforms) {
      if (platform.x + platform.w < cam - 100 || platform.x > cam + VIEW_W + 100) continue;
      g.fillStyle = platform.kind === 'bridge' ? '#86603c' : '#586070'; g.fillRect(platform.x, platform.y, platform.w, platform.h);
      g.fillStyle = platform.kind === 'bridge' ? '#bd8b53' : '#8490a3'; g.fillRect(platform.x, platform.y, platform.w, 4);
    }
    if (world.stage.mechanic === 'lava') {
      g.fillStyle = '#ff5b22';
      for (const gap of world.gaps) g.fillRect(gap[0], GROUND_Y + 16, gap[1] - gap[0], 104);
      if (world.lavaWarning > 0) { g.globalAlpha = world.lavaWarning * 0.55; g.fillStyle = '#ff4b20'; g.fillRect(cam, GROUND_Y - 28, VIEW_W, 152); g.globalAlpha = 1; }
    }
    for (const brazier of world.braziers) {
      g.fillStyle = '#654329'; g.fillRect(brazier.x + 8, brazier.y + 18, 18, 20);
      const flick = Math.sin(world.elapsed * 8 + brazier.x) * 4;
      g.fillStyle = '#ffb33d'; g.beginPath(); g.arc(brazier.x + 17, brazier.y + 12, 13 + flick * 0.2, 0, Math.PI * 2); g.fill();
      g.fillStyle = '#fff27a'; g.beginPath(); g.arc(brazier.x + 17, brazier.y + 12, 6, 0, Math.PI * 2); g.fill();
    }
    for (const core of world.cores) {
      if (core.dead) continue;
      g.fillStyle = '#ff632f'; g.beginPath(); g.moveTo(core.x, core.y + core.h); g.lineTo(core.x + core.w / 2, core.y); g.lineTo(core.x + core.w, core.y + core.h); g.fill();
      drawBar(core.x, core.y - 9, core.w, 5, core.hp / core.maxHp, '#ff8f43');
    }
    for (const chest of world.chests) {
      if (chest.opened) { g.fillStyle = '#5c4026'; g.fillRect(chest.x, chest.y + 18, chest.w, 14); continue; }
      g.fillStyle = chest.key ? '#dbb84f' : '#9b6737'; g.fillRect(chest.x, chest.y, chest.w, chest.h);
      g.fillStyle = '#ffd66b'; g.fillRect(chest.x, chest.y + 13, chest.w, 5); g.fillRect(chest.x + 15, chest.y + 9, 6, 13);
    }
    g.fillStyle = world.gateOpen ? '#55df7c' : '#c55252';
    g.fillRect(world.gate.x, world.gate.y, world.gate.w, world.gate.h);
    g.fillStyle = '#11151f'; g.fillRect(world.gate.x + 13, world.gate.y + 18, world.gate.w - 26, world.gate.h - 18);
    g.fillStyle = '#ffe66d'; g.font = '10px "Press Start 2P", monospace'; g.fillText(world.gateOpen ? 'OPEN' : 'LOCK', world.gate.x + 7, world.gate.y - 8);

    for (const d of world.drops) {
      const bob = Math.sin(world.elapsed * 5 + d.x) * 3;
      g.fillStyle = d.kind === 'gold' ? '#ffe66d' : d.kind === 'item' ? rarityColor(d.payload.rarity) : d.kind === 'hp' ? '#ff5f65' : d.kind === 'mp' ? '#5c8cff' : '#fff1a6';
      g.beginPath(); g.arc(d.x + 12, d.y + 12 + bob, 9, 0, Math.PI * 2); g.fill();
      g.strokeStyle = '#111'; g.stroke();
    }
    for (const p of world.projectiles.concat(world.enemyProjectiles)) {
      g.fillStyle = p.color; g.beginPath(); g.ellipse(centerX(p), centerY(p), p.w / 2, p.h / 2, 0, 0, Math.PI * 2); g.fill();
    }
    for (const e of world.enemies) drawEnemy(e);
    drawPlayer();
    for (const effect of world.effects) drawEffect(effect);
    for (const f of world.floats) {
      g.globalAlpha = clamp(f.life / f.maxLife, 0, 1); g.font = (f.size || 12) + 'px "Press Start 2P", monospace'; g.textAlign = 'center';
      g.fillStyle = 'rgba(0,0,0,.75)'; g.fillText(f.text, f.x + 2, f.y + 2); g.fillStyle = f.color; g.fillText(f.text, f.x, f.y);
    }
    g.globalAlpha = 1; g.textAlign = 'left';
    g.restore();
  }

  function drawEnemy(e) {
    if (e.dead) return;
    const flash = e.hitFlash > 0;
    g.fillStyle = flash ? '#ffffff' : (e.elite ? e.elite.color : e.def.color);
    if (e.role === 'flying') { g.beginPath(); g.ellipse(centerX(e), centerY(e), e.w / 2, e.h / 2, 0, 0, Math.PI * 2); g.fill(); }
    else { g.fillRect(e.x, e.y, e.w, e.h); }
    g.fillStyle = '#111';
    const eyeX = e.face > 0 ? e.x + e.w - 11 : e.x + 6; g.fillRect(eyeX, e.y + 10, 5, 5);
    if (e.role === 'shield') { g.strokeStyle = '#b6d7e8'; g.lineWidth = 5; const sx = e.face > 0 ? e.x + e.w + 1 : e.x - 1; g.beginPath(); g.moveTo(sx, e.y + 5); g.lineTo(sx, e.y + e.h - 3); g.stroke(); }
    if (e.frozen > 0) { g.strokeStyle = '#8de4ff'; g.lineWidth = 3; g.strokeRect(e.x - 2, e.y - 2, e.w + 4, e.h + 4); }
    if (e.burn > 0) { g.fillStyle = '#ff7b34'; g.beginPath(); g.arc(centerX(e), e.y - 4, 7, 0, Math.PI * 2); g.fill(); }
    if (e.elite) { g.strokeStyle = e.elite.color; g.lineWidth = 2; g.strokeRect(e.x - 4, e.y - 4, e.w + 8, e.h + 8); }
    drawBar(e.x, e.y - 12, e.w, e.role === 'boss' ? 7 : 5, e.hp / e.maxHp, e.role === 'boss' ? '#ff3f3f' : '#e66767');
    if (e.elite || e.role === 'boss') {
      g.font = '8px "Press Start 2P", monospace'; g.textAlign = 'center'; g.fillStyle = e.elite ? e.elite.color : '#ff6969';
      g.fillText((e.elite ? '[' + e.elite.name + '] ' : '') + e.def.name, centerX(e), e.y - 18); g.textAlign = 'left';
    }
    if (e.role === 'charger' && e.state === 'telegraph') { g.strokeStyle = '#ff4f4f'; g.setLineDash([8, 6]); g.beginPath(); g.moveTo(centerX(e), GROUND_Y - 4); g.lineTo(centerX(e) + e.face * 260, GROUND_Y - 4); g.stroke(); g.setLineDash([]); }
  }

  function drawPlayer() {
    if (!player) return;
    const cls = RPG.CLASS_DEFS[profile.classId];
    if (player.invuln > 0 && Math.floor(player.invuln * 16) % 2 === 0) g.globalAlpha = 0.35;
    g.fillStyle = cls.color; g.fillRect(player.x, player.y, player.w, player.h);
    g.fillStyle = '#f6d2a8'; g.fillRect(player.x + 6, player.y + 5, 20, 14);
    g.fillStyle = '#111'; g.fillRect(player.face > 0 ? player.x + 21 : player.x + 7, player.y + 9, 4, 4);
    g.fillStyle = cls.color; g.fillRect(player.face > 0 ? player.x - 4 : player.x + 12, player.y, 24, 6);
    if (player.guardT > 0) { g.strokeStyle = '#81d4ff'; g.lineWidth = 4; g.beginPath(); g.arc(centerX(player), centerY(player), 34, 0, Math.PI * 2); g.stroke(); }
    g.globalAlpha = 1;
  }

  function drawEffect(e) {
